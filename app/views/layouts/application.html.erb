<!DOCTYPE html>
<html>
  <head>
    <title>AtelierLapieuvre</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Vite client (nécessaire pour HMR en dev et manifest en prod) -->
    <%= vite_client_tag %>

  </head>

  <body>
    <!-- Conteneurs React requis -->
    <div id="root"></div>
    <div id="realisations-react-root"></div>
    <div id="atelier-root"></div>

    <!-- Messages flash Devise -->
    <% if notice %>
      <p class="notice"><%= notice %></p>
    <% end %>
    <% if alert %>
      <p class="alert"><%= alert %></p>
    <% end %>
    <!-- Contenu Rails classique -->
    <div id="rails-content">
      <%= yield %>
    </div>

    <!-- Cloudinary Upload Widget -->
    <script src="https://widget.cloudinary.com/v2.0/global/all.js"></script>
  </body>
</html>